# ============================================================
# LobeHub — Variáveis para deploy no Dokploy
# Configure estas variáveis em: Dokploy → App → Environment
# ============================================================

# ── URL pública do app ──────────────────────────────────────
APP_URL=https://app.seudominio.com
AUTH_TRUSTED_ORIGINS=https://app.seudominio.com

# ── Segredos (gere com: openssl rand -base64 32) ───────────
AUTH_SECRET=GERE_COM_openssl_rand_base64_32
KEY_VAULTS_SECRET=GERE_COM_openssl_rand_base64_32

# ── Banco de dados PostgreSQL (externo — ex: Neon) ─────────
DATABASE_URL=postgresql://user:senha@host/dbname?sslmode=require

# ── Redis (addon Dokploy ou externo) ───────────────────────
REDIS_URL=redis://default:senha@host:6379
REDIS_PREFIX=lobehub

# ── Auth: Email/Senha ───────────────────────────────────────
# Descomente para desativar registro por email (só SSO)
# AUTH_DISABLE_EMAIL_PASSWORD=1

# Restringe cadastro a esses emails (opcional)
# AUTH_ALLOWED_EMAILS=admin@seudominio.com

# ── Auth: OAuth (opcional) ─────────────────────────────────
# GitHub
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# Google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ── LLM Providers — configure o(s) que for usar ────────────
# OpenRouter (substitui OpenAI + outros)
# OPENROUTER_API_KEY=sk-or-...

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_PROXY_URL=   # opcional

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GOOGLE_API_KEY=

# ── S3 / Armazenamento de arquivos (opcional) ──────────────
# S3_ENDPOINT=https://...
# S3_BUCKET=lobehub
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENABLE_PATH_STYLE=1
# NEXT_PUBLIC_S3_DOMAIN=https://...
